generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model membership {
  id       Int            @id @default(autoincrement())
  type     membership_type @relation(fields: [typeId], references: [id])
  typeId   Int
  userId   Int
  user     users          @relation(fields: [userId], references: [id])
  expiration DateTime
}

model membership_type {
  id                    Int                    @id @default(autoincrement())
  name                  String
  price                 Decimal                @db.Decimal(10, 2) @default(0)
  memberships           membership[]
  facilities_membership facilities_membership[]
}

model facilities_membership {
  id                Int           @id @default(autoincrement())
  facilityId        Int
  membershipTypeId  Int
  facility          facilities   @relation(fields: [facilityId], references: [id])
  type              membership_type @relation(fields: [membershipTypeId], references: [id])
}

model facilities {
  id                     Int                    @id @default(autoincrement())
  type                   String
  capacity               Int
  responsibleWorker      Int
  responsibleWorkerUser  users?                 @relation("FacilityResponsible", fields: [responsibleWorker], references: [id])
  assistantWorker        Int?
  assistantWorkerUser    users?                 @relation("FacilityAssistant", fields: [assistantWorker], references: [id])
  isActive               Boolean
  activities             activity[]
  facilities_membership  facilities_membership[]
}

model activity {
  /*
    id: number;
  name: string;
  type: string;
  startAt: Date;
  endAt: Date;
  userId: number;
  cost: number;
  facility: Facility;
  isActive: boolean;
  */
  id Int @id @default(autoincrement())
  name String
  type String
  startAt DateTime
  endAt DateTime
  userId Int
  user     users     @relation(fields: [userId], references: [id])
  cost Decimal @db.Decimal(10, 2)
  facilityId Int
  facility facilities @relation(fields: [facilityId], references: [id])
  isActive Boolean
}

model user_type {
  id    Int     @id @default(autoincrement())
  name  String
  users users[]
}

model users {
  /*
    name: string;
  type: UserType;
  email?: string;
  password?: string;
  createdAt?: Date;
  deletedAt?: Date;
  isActive?: boolean;
  membership?: MembershipType;
  role?: MemberRole | WorkerRole;
  salary?: number;
  hoursToWorkPerDay?: number;
  startWorkAt?: Date;
  endWorkAt?: Date;
  weight?: number;
  height?: number;
  gender?: Gender;
  birthDate?: Date;
  diet?: string;
  trainingPlan?: string;
  medicalHistory?: string;
  allergies?: string;
  medications?: string;
  medicalConditions?: string;
  */

  
  id Int @id @default(autoincrement())
  name String
  typeId Int
  type user_type @relation(fields: [typeId], references: [id])
  email String?
  password String?
  createdAt DateTime @default(now())
  deletedAt DateTime?
  isActive Boolean
  memberships              membership[]
  activities               activity[]
  facilitiesAsResponsible  facilities[] @relation("FacilityResponsible")
  facilitiesAsAssistant    facilities[] @relation("FacilityAssistant")
  salary Decimal? @db.Decimal(10, 2)
  hoursToWorkPerDay Int?
  startWorkAt DateTime?
  endWorkAt DateTime?
  weight Decimal? @db.Decimal(10, 2)
  height Decimal? @db.Decimal(10, 2)
  gender String?
  birthDate DateTime?
  diet String?
  trainingPlan String?
  medicalHistory String?
  allergies String?
  medications String?
  medicalConditions String?
}